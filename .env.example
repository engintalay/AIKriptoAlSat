# AI Kripto Al-Sat Yapılandırma Dosyası

# Gemini API Anahtarınız (Yapay Zeka analizi ve Chat için gereklidir)
# Boş bırakılırsa uygulama otomatik olarak simülasyon (Mock) modunda çalışır.
GEMINI_API_KEY=your_gemini_api_key_here

# Sunucu Ayarları
HOST=127.0.0.1
PORT=8000

# Tarayıcı Ayarları
# En yüksek hacimli kaç coin taranacak (Binance üzerindeki USDT çiftleri)
TOP_COINS_LIMIT=50
# Tarama aralığı (Dakika cinsinden - arka planda verileri günceller)
SCAN_INTERVAL_MINUTES=15

# Yapay Zeka Sağlayıcısı Ayarları
# Sağlayıcı tipi: gemini veya ollama (Varsayılan: gemini)
LLM_PROVIDER=gemini
# Ollama yerel model adı ve API URL'si
OLLAMA_MODEL=llama3
OLLAMA_API_URL=http://localhost:11434

# llama.cpp yerel sunucu API URL'si
LLAMACPP_API_URL=http://localhost:8080
